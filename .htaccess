Options -Indexes

# ── Güvenlik Başlıkları ─────────────────────────────────────────────────────
<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set X-XSS-Protection "1; mode=block"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
    # HSTS: Yalnızca HTTPS üzerinde deployment yapılıyorsa etkinleştirin
    # Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
</IfModule>

# ── Gzip Sıkıştırma ─────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json text/plain text/xml
</IfModule>

# ── Statik Dosya Cache ───────────────────────────────────────────────────────
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css                  "access plus 1 month"
    ExpiresByType application/javascript    "access plus 1 month"
    ExpiresByType image/webp                "access plus 3 months"
    ExpiresByType image/png                 "access plus 3 months"
    ExpiresByType image/jpeg                "access plus 3 months"
    ExpiresByType image/svg+xml             "access plus 1 month"
    ExpiresByType font/woff2                "access plus 1 year"
    ExpiresByType application/manifest+json "access plus 1 day"
    ExpiresByType text/html                 "access plus 0 seconds"
</IfModule>

RewriteEngine On

# API klasörüne dokunma, PHP doğrudan çalışsın
RewriteRule ^api/ - [L]

# Gerçek dosya veya klasörse dokunma
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# Diğer her şeyi index.html'e gönder
RewriteRule ^ index.html [QSA,L]